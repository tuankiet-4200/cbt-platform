{
  "name": "cbt-platform",
  "version": "1.0.0",
  "description": "Computer-Based Testing Platform — TSA HUST Simulation",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w apps/api && npm run build -w apps/web",
    "lint": "npm run lint -w apps/api && npm run lint -w apps/web",
    "typecheck": "npm run typecheck -w apps/api && npm run typecheck -w apps/web",
    "test": "npm run test -w apps/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "db:migrate": "npm run prisma:migrate -w apps/api",
    "db:studio": "npm run prisma:studio -w apps/api",
    "db:seed": "npm run prisma:seed -w apps/api"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "@scarf/scarf@1.4.0": true,
    "bcrypt@5.1.1": true,
    "esbuild@0.25.12": true,
    "msgpackr-extract@3.0.4": true,
    "prisma@6.19.3": true,
    "@nestjs/core@10.4.22": true,
    "fsevents@2.3.3": true
  }
}
