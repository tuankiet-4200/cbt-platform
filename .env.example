# =============================================================================
# CBT PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values
# =============================================================================

# ── Node Environment ──────────────────────────────────────────────────────────
NODE_ENV=development

# ── API Server ────────────────────────────────────────────────────────────────
API_PORT=3000
API_PREFIX=api/v1

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api/v1

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=cbt_user
POSTGRES_PASSWORD=cbt_password_dev
POSTGRES_DB=cbt_platform

# Prisma DATABASE_URL (auto-constructed from above for local dev)
DATABASE_URL=postgresql://cbt_user:cbt_password_dev@localhost:5432/cbt_platform?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Full Redis URL (used by BullMQ)
REDIS_URL=redis://localhost:6379

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_64_FOR_ACCESS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_64_FOR_REFRESH
JWT_REFRESH_EXPIRES_IN=7d

# ── File Storage (Supabase Storage) ───────────────────────────────────────────
# Keep service role key backend-only. Never expose it to Vite/frontend code.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_IMAGES_BUCKET=images
SUPABASE_CONTRIBUTIONS_BUCKET=contributions

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM="CBT Platform <noreply@cbt-platform.com>"

# ── pgAdmin (Docker only) ─────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@cbt-platform.com
PGADMIN_PASSWORD=admin123

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
