// =============================================================================
// CBT PLATFORM — PRISMA SCHEMA
// Database: PostgreSQL 16
// ORM: Prisma 6.x
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  ADMIN
  USER
}

/// Lifecycle of a community-contributed PDF/DOCX submission
enum ContributionStatus {
  PENDING    // Uploaded by community member, awaiting admin review
  REVIEWING  // Admin is actively reviewing / entering questions
  APPROVED   // Admin has entered all questions; contributor credited
  REJECTED   // Rejected (duplicate, illegible, off-topic, etc.)
}

/// Lifecycle status of a question / passage bundle in the question bank
enum QuestionStatus {
  DRAFT          // Being created, not yet submitted for review
  PENDING_REVIEW // Submitted by contributor, awaiting Admin review
  PUBLISHED      // Approved and available for exam generation
  ARCHIVED       // Retired, no longer used in new exams
}

/// Question format — determines which renderer component to use on FE
enum QuestionType {
  SINGLE_CHOICE     // Radio buttons — 1 correct answer from N options
  MULTIPLE_CHOICE   // Checkboxes — ALL correct options must be selected (all-or-nothing)
  TRUE_FALSE_MATRIX // Table with statements — Đúng/Sai per row (all-or-nothing)
  DRAG_DROP         // Drag items into target slots (all-or-nothing)
  FILL_NUMBER       // Numeric input blanks — exact match, all blanks must be correct (all-or-nothing)
}

/// TSA Exam section type — determines layout and score grouping
enum ExamSectionType {
  MATH     // Toán học — individual standalone questions, single-column layout
  READING  // Đọc hiểu — PassageBundle of exactly 10 questions, 2-column layout
  SCIENCE  // Khoa học (Lý/Hoá/Sinh) — PassageBundle of exactly 5 questions, 2-column layout
}

/// Cognitive level based on Bloom's Taxonomy (adapted for Vietnamese curriculum)
enum CognitiveLevel {
  RECOGNITION       // Nhận biết
  COMPREHENSION     // Thông hiểu
  APPLICATION       // Vận dụng
  HIGH_APPLICATION  // Vận dụng cao
}

/// Status of an exam session
enum SessionStatus {
  IN_PROGRESS // Currently being taken
  SUBMITTED   // Submitted by user (awaiting grading)
  GRADED      // Grading complete
  ABANDONED   // Session expired or abandoned
}

/// Exam access type
enum ExamAccessType {
  PUBLIC   // Auto-granted to all registered users (default exam)
  LOCKED   // Requires a valid AccessCode to unlock
}

// =============================================================================
// CORE ENTITIES
// =============================================================================

/// Platform users (students and admins)
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  role         UserRole @default(USER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // ── Relations ─────────────────────────────────────────────────────────────
  refreshTokens         RefreshToken[]
  examAccesses          ExamAccess[]
  sessions              ExamSession[]
  authoredQuestions     Question[]               @relation("QuestionAuthor")
  reviewedQuestions     Question[]               @relation("QuestionReviewer")
  authoredBundles       PassageBundle[]          @relation("BundleAuthor")
  reviewedBundles       PassageBundle[]          @relation("BundleReviewer")
  createdAccessCodes    AccessCode[]             @relation("AccessCodeCreator")
  contributions         ContributionSubmission[] @relation("ContributionSubmitter")
  reviewedContributions ContributionSubmission[] @relation("ContributionReviewer")

  @@map("users")
}

/// JWT Refresh Tokens (enables rotation and revocation)
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique // Hashed token stored in DB
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// =============================================================================
// COMMUNITY CONTRIBUTIONS
// =============================================================================

/// A community-submitted exam source file (PDF or DOCX).
///
/// Workflow:
///   1. Registered USER uploads a PDF/DOCX of a past exam they found.
///   2. Status = PENDING; admin is notified.
///   3. Admin reviews the file, changes status = REVIEWING.
///   4. Admin manually enters each question/bundle into the question bank,
///      setting authorId = submission.submitterId so the contributor gets public credit.
///   5. Admin marks status = APPROVED; contributor is shown attribution on every question.
///   6. Admin may optionally reward the contributor by creating an ExamAccess record.
///
/// The contributor does NOT need to know LaTeX — they just upload the original source.
model ContributionSubmission {
  id          String             @id @default(uuid())
  submitterId String             @map("submitter_id")

  /// Human-readable title for admin to identify the submission
  title       String             // e.g., "Đề TSA 2025 - Bách Khoa"
  description String?            // Optional context from the contributor

  /// Cloud storage URL of the uploaded file (S3 / GCS presigned or permanent URL)
  fileUrl     String             @map("file_url")

  /// 'PDF' | 'DOCX'
  fileType    String             @map("file_type")

  status      ContributionStatus @default(PENDING)

  /// Admin's feedback shown to the contributor (reason for rejection, etc.)
  adminNote   String?            @map("admin_note")

  reviewedById String?   @map("reviewed_by_id")
  reviewedAt   DateTime? @map("reviewed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // ── Relations ─────────────────────────────────────────────────────────────
  submitter   User           @relation("ContributionSubmitter", fields: [submitterId], references: [id])
  reviewedBy  User?          @relation("ContributionReviewer", fields: [reviewedById], references: [id])

  /// Questions entered by admin from this submission
  questions Question[]

  /// Passage bundles entered by admin from this submission
  bundles   PassageBundle[]

  @@index([submitterId])
  @@index([status])
  @@map("contribution_submissions")
}

// =============================================================================
// QUESTION BANK
// =============================================================================

/// Hierarchical content taxonomy (Subject → Chapter → Topic → SubTopic)
model Tag {
  id         String  @id @default(uuid())
  name       String
  slug       String  @unique // URL-safe identifier
  parentId   String? @map("parent_id")
  depth      Int     @default(0) // 0=Subject, 1=Chapter, 2=Topic, 3=SubTopic
  orderIndex Int     @default(0) @map("order_index")

  parent    Tag?          @relation("TagHierarchy", fields: [parentId], references: [id])
  children  Tag[]         @relation("TagHierarchy")
  questions QuestionTag[]
  bundles   PassageBundleTag[]

  @@index([parentId])
  @@map("tags")
}

/// An individual question in the question bank.
///
/// MATH questions are standalone: they can be picked individually into an exam.
/// READING/SCIENCE questions must belong to a PassageBundle and are
/// always selected as part of their bundle — never in isolation.
///
/// contentJson schema: see docs/QuestionContentSpec.md
///
/// authorId semantics: the person who gets PUBLIC CREDIT displayed to students.
/// For community-contributed questions, admin sets authorId = contributor's userId.
/// For admin-created questions, authorId = admin's own userId.
model Question {
  id    String         @id @default(uuid())
  type  QuestionType
  status QuestionStatus @default(DRAFT)
  level  CognitiveLevel @default(RECOGNITION)

  /// Full question content stored as JSONB (see QuestionContentSpec.md v2.1)
  contentJson Json @map("content_json") @db.JsonB

  /// IRT 3PL parameters: { a, b, c }
  /// Admin may override on creation; defaults to { a:1.0, b:0.0, c:0.25 }
  irtParams Json @default("{\"a\": 1.0, \"b\": 0.0, \"c\": 0.25}") @map("irt_params") @db.JsonB

  /// Expected solving time in seconds (used for time-analysis in Sprint 4)
  expectedTimeSecs Int @default(90) @map("expected_time_secs")

  authorId     String    @map("author_id")
  reviewedById String?   @map("reviewed_by_id")
  reviewNote   String?   @map("review_note")
  publishedAt  DateTime? @map("published_at")

  /// Link to the community submission this question was entered from.
  /// null = question was created directly by admin (not from a community upload).
  contributionId String? @map("contribution_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── Relations ─────────────────────────────────────────────────────────────
  author         User                       @relation("QuestionAuthor", fields: [authorId], references: [id])
  reviewedBy     User?                      @relation("QuestionReviewer", fields: [reviewedById], references: [id])
  contribution   ContributionSubmission?    @relation(fields: [contributionId], references: [id])
  tags           QuestionTag[]
  bundleQuestion PassageBundleQuestion?     // null = standalone MATH question
  mathExamItems  ExamMathQuestion[]
  sessionAnswers SessionAnswer[]

  @@index([status])
  @@index([type])
  @@index([level])
  @@index([authorId])
  @@index([contributionId])
  // GIN index on contentJson (applied via raw SQL in migration: docs/manual_indexes.sql)
  @@map("questions")
}

/// Many-to-many: Question ↔ Tag
model QuestionTag {
  questionId String @map("question_id")
  tagId      String @map("tag_id")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
  @@map("question_tags")
}

/// Many-to-many: PassageBundle ↔ Tag
model PassageBundleTag {
  bundleId String @map("bundle_id")
  tagId    String @map("tag_id")

  bundle PassageBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  tag    Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([bundleId, tagId])
  @@map("passage_bundle_tags")
}

// =============================================================================
// PASSAGE BUNDLES (Question Bank Layer)
// =============================================================================

/// A PassageBundle is an ATOMIC unit in the question bank.
///
/// It represents one reading passage (or science stimulus) paired with a
/// FIXED set of questions. The bundle is ALWAYS treated as a single unit:
///   - Admin uploads the passage text + all questions together.
///   - Exam generation selects whole bundles — questions CANNOT be split.
///   - READING bundles must have exactly 10 questions.
///   - SCIENCE bundles must have exactly 5 questions.
///   (Cardinality rule enforced at application layer, not DB level.)
///
/// This model lives in the Question Bank, NOT in any specific Exam.
///
/// authorId semantics: same as Question — the person credited publicly.
/// For community contributions, admin sets authorId = contributor's userId.
model PassageBundle {
  id          String          @id @default(uuid())
  sectionType ExamSectionType @map("section_type") // READING or SCIENCE only

  /// Short title displayed in admin UI (e.g., "Đọc hiểu — Khán giá học")
  title String?

  /// Full passage / stimulus text as RichTextNode[]
  /// Supports: text, latex, latex_block, image, bold, italic, break
  contentJson Json @map("content_json") @db.JsonB

  /// Expected total time for the whole bundle in seconds
  expectedTimeSecs Int @default(600) @map("expected_time_secs")

  status       QuestionStatus @default(DRAFT)
  authorId     String         @map("author_id")
  reviewedById String?        @map("reviewed_by_id")
  reviewNote   String?        @map("review_note")
  publishedAt  DateTime?      @map("published_at")

  /// Link to the community submission this bundle was entered from.
  /// null = created directly by admin.
  contributionId String? @map("contribution_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── Relations ─────────────────────────────────────────────────────────────
  author       User                     @relation("BundleAuthor", fields: [authorId], references: [id])
  reviewedBy   User?                    @relation("BundleReviewer", fields: [reviewedById], references: [id])
  contribution ContributionSubmission?  @relation(fields: [contributionId], references: [id])
  tags         PassageBundleTag[]
  questions    PassageBundleQuestion[]
  examItems    ExamPassageBundle[]

  @@index([sectionType, status])
  @@index([authorId])
  @@index([contributionId])
  @@map("passage_bundles")
}

/// Ordered mapping: PassageBundle → Question
///
/// Each bundle owns exactly N questions (10 for READING, 5 for SCIENCE).
/// orderInBundle determines the display order in the right column of the 2-column layout.
/// points is the score for a fully-correct answer to this question.
model PassageBundleQuestion {
  bundleId      String @map("bundle_id")
  questionId    String @unique @map("question_id") // A question belongs to AT MOST 1 bundle
  orderInBundle Int    @map("order_in_bundle")     // 0-based display order in right column
  points        Float  @default(1.0)               // Points for this question (all-or-nothing per question type rules)

  bundle   PassageBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  question Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([bundleId, questionId])
  @@unique([bundleId, orderInBundle])
  @@index([bundleId])
  @@map("passage_bundle_questions")
}

// =============================================================================
// EXAM MANAGEMENT
// =============================================================================

/// An exam (collection of questions with time limit).
///
/// An exam is assembled from:
///   1. ExamMathQuestion records  — individual MATH questions
///   2. ExamPassageBundle records — whole PassageBundles for READING/SCIENCE
model Exam {
  id           String         @id @default(uuid())
  title        String
  description  String?
  instructions String?        // Displayed before exam starts (Markdown)
  durationMins Int            @map("duration_mins")
  totalPoints  Float          @default(0) @map("total_points")
  accessType   ExamAccessType @default(LOCKED)
  isPublished  Boolean        @default(false) @map("is_published")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  // ── Relations ─────────────────────────────────────────────────────────────
  mathQuestions   ExamMathQuestion[]
  passageBundles  ExamPassageBundle[]
  accessCodes     AccessCode[]
  accesses        ExamAccess[]
  sessions        ExamSession[]

  @@map("exams")
}

/// An individual MATH question placed into an exam.
/// MATH questions are standalone — no passage, no bundle constraint.
model ExamMathQuestion {
  id         String @id @default(uuid())
  examId     String @map("exam_id")
  questionId String @map("question_id")

  /// 0-based order within the MATH section of this exam
  orderInSection Int   @map("order_in_section")
  points         Float @default(1.0)

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@unique([examId, questionId])
  @@unique([examId, orderInSection])
  @@index([examId])
  @@map("exam_math_questions")
}

/// A PassageBundle selected into an exam (READING or SCIENCE section).
///
/// Selecting a bundle atomically includes its passage text AND all its questions.
/// You cannot select individual questions from a bundle.
///
/// orderInSection is the display order of this bundle within its section:
///   e.g., READING bundle 0 → bundle 1 → bundle 2 (each with 10 questions)
model ExamPassageBundle {
  id              String          @id @default(uuid())
  examId          String          @map("exam_id")
  passageBundleId String          @map("passage_bundle_id")
  sectionType     ExamSectionType @map("section_type") // READING or SCIENCE

  /// 0-based order of this bundle within its section in this exam
  orderInSection Int @map("order_in_section")

  exam          Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  passageBundle PassageBundle @relation(fields: [passageBundleId], references: [id])

  @@unique([examId, passageBundleId])                  // Same bundle can't appear twice in an exam
  @@unique([examId, sectionType, orderInSection])      // Ordering is unique per section
  @@index([examId])
  @@index([examId, sectionType])
  @@map("exam_passage_bundles")
}

/// Access codes that unlock exams for users
model AccessCode {
  id          String    @id @default(uuid())
  code        String    @unique // 8-char alphanumeric uppercase
  examId      String    @map("exam_id")
  maxUses     Int?      @map("max_uses")    // null = unlimited
  usedCount   Int       @default(0) @map("used_count")
  expiresAt   DateTime? @map("expires_at") // null = never expires
  isActive    Boolean   @default(true) @map("is_active")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  exam      Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  createdBy User         @relation("AccessCodeCreator", fields: [createdById], references: [id])
  accesses  ExamAccess[]

  @@index([examId])
  @@index([code])
  @@map("access_codes")
}

/// Records which exams a user has unlocked (and how)
model ExamAccess {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  examId       String   @map("exam_id")
  accessCodeId String?  @map("access_code_id") // null = auto-granted (PUBLIC exam)
  grantedAt    DateTime @default(now()) @map("granted_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam       Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  accessCode AccessCode? @relation(fields: [accessCodeId], references: [id])

  @@unique([userId, examId])
  @@index([userId])
  @@index([examId])
  @@map("exam_accesses")
}

// =============================================================================
// EXAM SESSION (Test-Taking Engine)
// =============================================================================

/// An individual exam attempt by a user
model ExamSession {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  examId      String        @map("exam_id")
  status      SessionStatus @default(IN_PROGRESS)
  startTime   DateTime      @default(now()) @map("start_time")
  endTime     DateTime      @map("end_time")     // startTime + exam.durationMins
  submittedAt DateTime?     @map("submitted_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // ── Relations ─────────────────────────────────────────────────────────────
  user             User              @relation(fields: [userId], references: [id])
  exam             Exam              @relation(fields: [examId], references: [id])
  answers          SessionAnswer[]
  result           ExamResult?
  proctoringEvents ProctoringEvent[]

  @@index([userId, examId])
  @@index([status])
  @@map("exam_sessions")
}

/// Persisted answer for a single question within a session.
/// NOTE: Answers are first buffered in Redis, then flushed here by BullMQ worker.
///
/// Works uniformly for both MATH and READING/SCIENCE questions —
/// the question always has a unique ID regardless of whether it came from
/// a standalone ExamMathQuestion or a PassageBundleQuestion.
model SessionAnswer {
  id         String @id @default(uuid())
  sessionId  String @map("session_id")
  questionId String @map("question_id")

  /// Raw answer submitted by user — type-specific JSON (see QuestionContentSpec.md)
  /// SINGLE_CHOICE:     { selectedOptionId: string }
  /// MULTIPLE_CHOICE:   { selectedOptionIds: string[] }
  /// TRUE_FALSE_MATRIX: { answers: { statementId: string, value: boolean }[] }
  /// DRAG_DROP:         { slots: { slotId: string, itemId: string }[] }
  /// FILL_NUMBER:       { blanks: { blankId: string, value: number }[] }
  answerJson Json? @map("answer_json") @db.JsonB

  isCorrect    Boolean? @map("is_correct")   // null until graded
  pointsEarned Float?   @map("points_earned")
  timeSpentMs  Int?     @map("time_spent_ms")
  attemptCount Int      @default(1) @map("attempt_count")
  answeredAt   DateTime @default(now()) @map("answered_at")

  session  ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])

  @@unique([sessionId, questionId])
  @@index([sessionId])
  @@map("session_answers")
}

/// Final computed result for a session (populated by grading worker)
model ExamResult {
  id           String @id @default(uuid())
  sessionId    String @unique @map("session_id")
  totalScore   Float  @map("total_score")
  maxScore     Float  @map("max_score")
  percentScore Float  @map("percent_score") // totalScore / maxScore * 100
  correctCount Int    @map("correct_count")
  wrongCount   Int    @map("wrong_count")
  skippedCount Int    @map("skipped_count")
  durationSecs Int    @map("duration_secs")

  /// Per-section score breakdown
  /// Schema: { section: 'MATH'|'READING'|'SCIENCE', score, maxScore, correct, total }[]
  sectionScores Json @default("[]") @map("section_scores") @db.JsonB

  /// Score breakdown by tag
  /// Schema: { tagId, tagName, correct, total }[]
  tagBreakdown Json @default("[]") @map("tag_breakdown") @db.JsonB

  completedAt DateTime @default(now()) @map("completed_at")

  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("exam_results")
}

// =============================================================================
// PROCTORING
// =============================================================================

/// Records of suspicious activity during a session
model ProctoringEvent {
  id        String @id @default(uuid())
  sessionId String @map("session_id")

  /// 'TAB_SWITCH' | 'FULLSCREEN_EXIT' | 'COPY_ATTEMPT' | 'SESSION_BLUR'
  eventType String @map("event_type")

  /// Additional context: { questionIndex?: number, duration?: number }
  metadata Json? @db.JsonB

  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  session ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([eventType])
  @@map("proctoring_events")
}
